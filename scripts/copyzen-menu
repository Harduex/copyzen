#!/bin/sh
# copyzen-menu — fuzzel-based clipboard picker for copyzen. Bind to Super+V.
#   Enter          copy selection (type-aware: images paste back as images)
#   Ctrl+S         pin/unpin (toggle) selection
#   Ctrl+Shift+D   delete selection      (confirm: press Enter, Esc cancels)
#   Ctrl+Shift+C   clear ALL history     (confirm: press Enter, Esc cancels)
#   Esc            quit
# fuzzel exits on every action key and cannot reload its list, so each action
# relaunches fuzzel; confirmations relaunch into a confirm-state view. Pinned items
# are never cleared by Ctrl+Shift+C — remove them one-by-one with Ctrl+Shift+D.
# No `set -e`: fuzzel's non-zero exits are control flow, not errors.
set -u

# ── dependency check ─────────────────────────────────────────────────────────
missing=""
for cmd in fuzzel wl-paste wl-copy copyzen; do
	command -v "$cmd" >/dev/null 2>&1 || missing="${missing:+$missing, }$cmd"
done
if [ -n "$missing" ]; then
	echo "copyzen-menu: missing required tools: $missing" >&2
	echo "" >&2
	# Detect package manager and suggest an install command.
	if command -v apt-get >/dev/null 2>&1; then
		pkgs="$(echo "$missing" | sed 's/wl-paste/wl-clipboard/;s/wl-copy/wl-clipboard/' | tr ',' '\n' | sort -u | tr '\n' ' ')"
		echo "  Install with:  sudo apt-get install $pkgs" >&2
	elif command -v dnf >/dev/null 2>&1; then
		pkgs="$(echo "$missing" | sed 's/wl-paste/wl-clipboard/;s/wl-copy/wl-clipboard/' | tr ',' '\n' | sort -u | tr '\n' ' ')"
		echo "  Install with:  sudo dnf install $pkgs" >&2
	elif command -v pacman >/dev/null 2>&1; then
		pkgs="$(echo "$missing" | sed 's/wl-paste/wl-clipboard/;s/wl-copy/wl-clipboard/' | tr ',' '\n' | sort -u | tr '\n' ' ')"
		echo "  Install with:  sudo pacman -S $pkgs" >&2
	elif command -v zypper >/dev/null 2>&1; then
		pkgs="$(echo "$missing" | sed 's/wl-paste/wl-clipboard/;s/wl-copy/wl-clipboard/' | tr ',' '\n' | sort -u | tr '\n' ' ')"
		echo "  Install with:  sudo zypper install $pkgs" >&2
	else
		echo "  Install the missing tools via your package manager." >&2
		echo "  (wl-paste and wl-copy are part of the 'wl-clipboard' package)" >&2
	fi
	exit 1
fi

config="${XDG_CONFIG_HOME:-$HOME/.config}/copyzen/fuzzel.ini"

# Base args for every fuzzel call. --with-nth (hides the id column) needs a newer
# fuzzel and is purely cosmetic, so it is added only to the main list, not the
# single-line confirm views (where there is no id column to hide).
set -- --dmenu --config "$config"
withnth=
if fuzzel --help 2>&1 | grep -q -- '--with-nth'; then
	withnth=--with-nth=2
fi
# fuzzel >= 1.11 can pre-highlight a row by index, so the highlight lands on the
# live entry instead of always on row 0. Older fuzzel can't, so the • marker
# (copyzen list --mark-active) stays as the fallback way to spot the live row.
selectindex=
if fuzzel --help 2>&1 | grep -q -- '--select-index'; then
	selectindex=1
fi
# Newer fuzzel colours the prompt input separately, defaulting to a solarized grey that
# clashes with the theme; set a neutral grey to match the terminal. Older fuzzel lacks the
# flag (the input then follows the `text` colour), so this stays additive — no default override.
if fuzzel --help 2>&1 | grep -q -- '--input-color'; then
	set -- "$@" --input-color=888888ff
fi

state=list
sel=

while :; do
	case "$state" in
	list)
		# When fuzzel supports it, pre-highlight the live row by its index (the
		# clipboard is read separately so its bytes — possibly binary — stay off the
		# shell variable, which would strip NULs). Falls back to the • marker alone.
		selidx=
		if [ -n "$selectindex" ]; then
			i=$(wl-paste --no-newline 2>/dev/null | copyzen active-index)
			[ -n "$i" ] && selidx="--select-index=$i"
		fi
		# Pipe the current clipboard in so copyzen can mark the live entry (•).
		sel=$(wl-paste --no-newline 2>/dev/null | copyzen list --mark-active | fuzzel "$@" $withnth $selidx)
		case "$?" in
		0)  if [ -n "$sel" ]; then
				t=$(printf '%s' "$sel" | copyzen mimetype)
				if [ -n "$t" ]; then
					printf '%s' "$sel" | copyzen decode | wl-copy --type "$t"
				else
					printf '%s' "$sel" | copyzen decode | wl-copy
				fi
			fi
			exit 0 ;;
		10) [ -n "$sel" ] && printf '%s' "$sel" | copyzen toggle ;;
		11) [ -n "$sel" ] && state=confirm-delete ;;
		12) state=confirm-clear ;;
		*)  exit 0 ;;
		esac
		;;
	confirm-delete)
		# Show only the targeted entry's preview (strip "id<TAB>"). Enter (exit 0)
		# confirms; Esc/anything else cancels. Deletes the captured id.
		preview=$(printf '%s' "$sel" | sed 's/^[0-9]*	//')
		printf '%s\n' "$preview" | fuzzel "$@" \
			--prompt '🗑 Delete? Enter = confirm · Esc = cancel ' >/dev/null
		[ "$?" -eq 0 ] && printf '%s' "$sel" | copyzen delete
		state=list
		;;
	confirm-clear)
		# Hide the list, show counts + a warning. Enter (exit 0) confirms; Esc cancels.
		counts=$(copyzen list | tr -d '\0' | awk -F'	' '
			{ total++; if ($2 ~ /^★/) pinned++ }
			END { printf "%d history items · %d pinned kept", total - pinned, pinned }')
		printf 'Clear %s\n' "$counts" | fuzzel "$@" \
			--prompt '⚠ Clear ALL history? Enter = confirm · Esc = cancel ' >/dev/null
		[ "$?" -eq 0 ] && copyzen wipe
		state=list
		;;
	esac
done
