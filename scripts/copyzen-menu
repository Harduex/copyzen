#!/bin/sh
# copyzen-menu — fuzzel-based clipboard picker for copyzen. Bind to Super+V.
#   Enter          copy selection (type-aware: images paste back as images)
#   Ctrl+S         pin/unpin (toggle) selection
#   Shift+Delete   delete selection      (confirm: press Enter, Esc cancels)
#   Ctrl+Shift+C   clear ALL history     (confirm: press Enter, Esc cancels)
#   Esc            quit
# fuzzel exits on every action key and cannot reload its list, so each action relaunches
# it; confirmations relaunch into a confirm-state view.
#
# The id column is hidden from the picker (so image thumbnails aren't crowded against the
# id): copyzen emits "id<TAB>preview[\0icon\x1f<path>]" to a temp file — a file, because
# shell variables/command-substitution strip the NUL the icon protocol needs — and we show
# fuzzel only field 2+ (preview + icon), then map fuzzel's --index back to the id.
# No `set -e`: fuzzel's non-zero exits are control flow, not errors.
set -u

config="${XDG_CONFIG_HOME:-$HOME/.config}/copyzen/fuzzel.ini"
rows=$(mktemp "${TMPDIR:-/tmp}/copyzen-menu.XXXXXX")
trap 'rm -f "$rows"' EXIT INT TERM

state=list
id=
idx=

while :; do
	case "$state" in
	list)
		wl-paste --no-newline 2>/dev/null | copyzen list --mark-active > "$rows"
		idx=$(cut -f2- "$rows" | fuzzel --dmenu --config "$config" --index)
		code=$?
		# Map the selected 0-based index back to its id (empty if nothing was selected;
		# fuzzel prints -1 / non-numeric when the input matched no entry).
		id=
		case "$idx" in
		'' | *[!0-9]*) ;;
		*) id=$(sed -n "$((idx + 1))p" "$rows" | cut -f1) ;;
		esac
		case "$code" in
		0)  if [ -n "$id" ]; then
				t=$(printf '%s' "$id" | copyzen mimetype)
				if [ -n "$t" ]; then
					printf '%s' "$id" | copyzen decode | wl-copy --type "$t"
				else
					printf '%s' "$id" | copyzen decode | wl-copy
				fi
			fi
			exit 0 ;;
		10) [ -n "$id" ] && printf '%s' "$id" | copyzen toggle ;;
		11) [ -n "$id" ] && state=confirm-delete ;;
		12) state=confirm-clear ;;
		*)  exit 0 ;;
		esac
		;;
	confirm-delete)
		# Show only the targeted row's preview (with its thumbnail). Enter (exit 0) confirms;
		# Esc/anything else cancels. Deletes the captured id.
		sed -n "$((idx + 1))p" "$rows" | cut -f2- |
			fuzzel --dmenu --config "$config" --prompt '🗑 Delete? Enter = confirm · Esc = cancel ' >/dev/null
		[ "$?" -eq 0 ] && printf '%s' "$id" | copyzen delete
		state=list
		;;
	confirm-clear)
		# Hide the list, show counts + a warning. Enter (exit 0) confirms; Esc cancels.
		# Pinned rows start with ★ (after the id column); strip NUL before counting.
		counts=$(tr -d '\0' < "$rows" | awk -F'	' '
			{ total++; if ($2 ~ /^★/) pinned++ }
			END { printf "%d history items · %d pinned kept", total - pinned, pinned }')
		printf 'Clear %s\n' "$counts" |
			fuzzel --dmenu --config "$config" --prompt '⚠ Clear ALL history? Enter = confirm · Esc = cancel ' >/dev/null
		[ "$?" -eq 0 ] && copyzen wipe
		state=list
		;;
	esac
done
